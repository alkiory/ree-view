# =============================================================================
# Frontend – Variables de entorno (plantilla)
# Copia este archivo a `.env` antes de iniciar Vite.
# Cualquier variable expuesta al cliente DEBE comenzar por el prefijo VITE_.
# =============================================================================

# URL del endpoint GraphQL del backend.
# - Desarrollo local (backend en tu máquina):
VITE_API_URL=http://localhost:3000/graphql
# - Dentro de Docker Compose (el servicio backend se llama `backend`):
# VITE_API_URL=http://backend:3000/graphql
# - Producción:
# VITE_API_URL=https://api.tu-dominio.com/graphql
