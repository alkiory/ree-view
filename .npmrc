# Paquetes autorizados a ejecutar build scripts (postinstall, install, etc.)
# pnpm 11 omite estos scripts salvo que aparezcan aquí. La lista refleja
# los paquetes que el CI de GitHub Pages reportó como ERR_PNPM_IGNORED_BUILDS
# en un runner limpio sin .pnpm-store cacheado.
# Cuando añadas una dependencia nueva con postinstall nativo (sharp, bcrypt,
# canvas, playwright, better-sqlite3, etc.), añádela también a esta lista o
# fallará el workflow.

# --- Build tools del frontend (Vite + plugin SWC) ---
only-built-dependencies[]=esbuild
only-built-dependencies[]=@swc/core

# --- Runtime de backend / GraphQL ---
only-built-dependencies[]=@nestjs/core
only-built-dependencies[]=@apollo/protobufjs

# --- Test infra (devDeps) ---
# Aunque el workflow solo ejecuta `pnpm --filter frontend build`,
# `pnpm install --frozen-lockfile` resuelve todo el workspace
# (frontend + backend), así que mongodb-memory-server necesita aquí
# su build aunque nunca se use en el step de build de prod.
only-built-dependencies[]=mongodb-memory-server
