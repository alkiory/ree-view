# =============================================================================
# Backend – Variables de entorno (plantilla)
# Copia este archivo a `.env` y rellena los valores antes de iniciar el server.
# =============================================================================

# --- Server --------------------------------------------------------------------
# Puerto en el que escucha NestJS.
PORT=3000

# --- CORS ----------------------------------------------------------------------
# Lista separada por comas con los orígenes del frontend autorizados.
# En local dev:   http://localhost:5173 (Vite)
# En Docker:      http://localhost:80 (nginx del contenedor frontend)
# En producción:  https://tu-dominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost

# --- MongoDB -------------------------------------------------------------------
# Cadena de conexión a MongoDB.
# Local sin Docker:
MONGODB_URI=mongodb://localhost:27017/energy-balance
# Con Docker Compose (el servicio mongo del compose expone 27017 al network):
# MONGODB_URI=mongodb://mongo:27017/energy-balance

# --- API de REE (Red Eléctrica de España) --------------------------------------
# Endpoint del balance eléctrico nacional (generación, demanda, etc.).
REE_API_URL=https://apidatos.ree.es/es/datos/balance/balance-electrico

# Endpoint de intercambios internacionales en fronteras físicas programadas.
REE_FRONTERAS_API_URL=https://apidatos.ree.es/es/datos/balance/todas-fronteras-fisicos-programados


# URL inválida usada solo como fallback para tests de manejo de errores
# (No cambiar en producción salvo que quieras simular fallos).
REE_API_URL_ERROR=https://apidatos.ree.es/invalid-endpoint

# --- Rate limiting (Tier 2) ---------------------------------------------------
# Ventana y límite por defecto del ThrottlerModule global (APP_GUARD).
# 30 req/min es suficiente para el dashboard de visualización.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=30

# Rate-limit más estricto para el controlador de debug /ree-client,
# expuesto fuera de GraphQL.
DEBUG_THROTTLE_LIMIT=5

# --- Validación de fechas (Tier 2) --------------------------------------------
# Rango máximo permitido entre startDate y endDate por query. 365 días
# (un año natural) cubre los casos de uso analíticos del dashboard
# (comparativa anual, balance mensual, histórico trimestral). Ajustable
# a 180 si prefieres semestral, o hasta 730 si la consulta de 2 años
# es un caso soportado por el rate-limit del throttle (ver THROTTLE_LIMIT).
# IMPORTANTE: este rango se traduce en UN solo request a REE
# (`energy-balance.service.ts:fetchMissingData`) — no se fragmenta en
# múltiples sub-queries, así que el THROTTLE_LIMIT aplica por query
# GraphQL (no por día de datos).
MAX_DATE_RANGE_DAYS=365

# --- Caché MongoDB (Tier 2) ----------------------------------------------------
# TTL en segundos del índice sobre `createdAt`; un día es razonable
# porque REE publica datos con micro-revisiones diarias.
CACHE_TTL_SECONDS=86400

# TTL en segundos del snapshot live (Fase 2). 60s coincide con el
# `pollInterval: 60000` del frontend para que cada minuto el snapshot
# se regenere contra REE. Subir este valor reduce carga sobre REE a
# costa de staleness en la UI «en vivo».
LIVE_CACHE_TTL_SECONDS=60

# --- Opcionales (legacy / no consumidos actualmente) ----------------------------
# Dejados por compatibilidad con configuraciones previas; se pueden eliminar
# limpiamente si confirmas que nada los lee.
# REE_API_TIMEOUT=5000   # ms
